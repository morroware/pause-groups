RewriteEngine On

# Deny access to data directory unconditionally
RewriteRule ^data/ - [F,L]

# Deny direct access to PHP files in lib/ and api/ directories
# (API routes like api/auth/login are virtual paths handled by index.php)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^(lib|api)/ - [F,L]

# Route everything else through index.php (except existing files/directories)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

# Deny access to sensitive file types
<FilesMatch "\.(db|lock|log|yaml|md)$">
    Require all denied
</FilesMatch>

<Files "config.php">
    Require all denied
</Files>

<Files "cron.php">
    Require all denied
</Files>

<Files "run_action.php">
    Require all denied
</Files>

<Files "install.php">
    # Blocked after initial setup. To run the installer, temporarily comment
    # out the line below, complete setup, then restore it immediately.
    Require all denied
</Files>
